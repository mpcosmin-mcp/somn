# ─── somn · sleep tracker v2 ───
# Copy this to `.env.local` and fill in real values for local dev.
# In production, set these in Vercel Project Settings → Environment Variables.

# Anthropic API key — used by /api/roast and /api/story
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional: override default Haiku model
# ANTHROPIC_MODEL=claude-haiku-4-5

# Google Apps Script Web App URL — REQUIRED. This is a bearer capability: anyone
# with it can read all rows (health + journals) and write/delete. Keep it env-only,
# never commit it. Rotate the deployment (new URL) if it leaks.
SHEETS_API_URL=

# ─── Garmin auto-sync (/api/garmin/sync, daily Vercel cron at 07:00 UTC = 10:00 RO vara) ───
# Unofficial Garmin Connect login — the account must NOT have MFA via app
# (email MFA is handled). GARMIN_PLAYER = exact Sheet name the entries get.
GARMIN_EMAIL=
GARMIN_PASSWORD=
GARMIN_PLAYER=Petrica Cosmin Moga

# Guards /api/garmin/sync in prod. Vercel cron sends it automatically as a
# Bearer header when this env var exists; manual runs: ?key=<CRON_SECRET>.
CRON_SECRET=
