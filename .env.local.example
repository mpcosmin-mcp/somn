# ─── somn · sleep tracker v2 ───
# Copy this to `.env.local` and fill in real values for local dev.
# In production, set these in Vercel Project Settings → Environment Variables.

# Anthropic API key — used by /api/roast and /api/story
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional: override default Haiku model
# ANTHROPIC_MODEL=claude-haiku-4-5

# Optional: override the Google Apps Script URL (defaults to the team's existing Sheet)
# SHEETS_API_URL=https://script.google.com/macros/s/.../exec

# ─── Phase 0: Neon + Clerk (see ROADMAP.md) ───
# Neon Postgres connection string. Provision via Vercel → Storage → Neon,
# which auto-injects this in prod. For local dev, paste the pooled URL here.
# DATABASE_URL=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Clerk auth (Google sign-in). Get these from the Clerk dashboard → API keys.
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
